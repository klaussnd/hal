// <algorithm> -*- C++ -*-

#ifndef _GLIBCXX_ALGORITHM
#define _GLIBCXX_ALGORITHM 1

namespace std
{
template <typename T>
inline T min(const T a, const T b)
{ return a < b ? a : b; }

template <typename T>
inline T max(const T a, const T b)
{ return a > b ? a : b; }
} // namespace std

#endif /* _GLIBCXX_ALGORITHM */
